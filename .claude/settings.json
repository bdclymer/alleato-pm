{
  "permissions": {
    "allow": [
      "mcp__playwright__browser_wait_for"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/check-design-system.sh",
            "timeout": 15,
            "statusMessage": "Checking design system compliance..."
          }
        ]
      }
    ]
  }
}
