  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$TOOL_INPUT\" | python3 -c \"import sys,json; d=json.load(sys.stdin); f=d.get('file_path',''); exit(0 if f.endswith('page.tsx') else 1)\" 2>/dev/null; then SKILL=\"/Users/meganharrison/Documents/alleato-pm/.claude/skills/create-page/SKILL.md\"; [ -f \"$SKILL\" ] && echo \"=== create-page skill injected ===\"  && cat \"$SKILL\"; fi"
          },
          {
            "type": "command",
            "command": "HOOK=\"${CLAUDE_PROJECT_DIR:-$PWD}/.claude/hooks/verify-feature-gate.py\"; [ -f \"$HOOK\" ] && echo \"$TOOL_INPUT\" | python3 \"$HOOK\" || exit 0"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "HOOK=\"${CLAUDE_PROJECT_DIR:-$PWD}/.claude/hooks/verify-feature-gate.py\"; [ -f \"$HOOK\" ] && echo \"$TOOL_INPUT\" | python3 \"$HOOK\" || exit 0"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$TOOL_INPUT\" | grep -q 'supabase/migrations'; then echo '\u26a0\ufe0f Migration file changed \u2014 run `npm run db:types` to regenerate database types'; fi"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "HOOK=\"${CLAUDE_PROJECT_DIR:-$PWD}/.claude/hooks/verify-feature-gate.py\"; [ -f \"$HOOK\" ] && CLAUDE_HOOK_EVENT=PostToolUse echo \"$TOOL_INPUT\" | CLAUDE_HOOK_EVENT=PostToolUse python3 \"$HOOK\" || exit 0"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --directory claude-memory-compiler-main python hooks/session-start.py",
            "timeout": 15
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
