# Production Environment Variables Template
# Copy this to .env.production and fill in the actual values

# Admin API Key — required for all mutation endpoints (ingest, graph sync, digests, admin)
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=your_admin_api_key_here

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_ORG_ID=your_openai_org_id_here

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# CORS Configuration (add your production domains)
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Server Configuration
PORT=8000
HOST=0.0.0.0

# Logging
LOG_LEVEL=INFO

# Sentry error monitoring, tracing, and logs
SENTRY_BACKEND_DSN=https://your-backend-dsn@oXXXX.ingest.us.sentry.io/XXXX
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILE_SESSION_SAMPLE_RATE=0
SENTRY_SEND_DEFAULT_PII=false


# Optional: API Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# Optional: Database Connection Pool
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
