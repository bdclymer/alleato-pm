#!/usr/bin/env sh

# Fast pre-commit: route check + root file guard + lint-staged only.
# Full typecheck and unit tests run in CI.

# ── Vercel author gate ───────────────────────────────────────────
# Vercel Hobby Plan blocks deployments from unauthorized commit authors.
# Block the commit locally so the broken deploy never ships.
# See docs/patterns/vercel-hobby-author-gate.md
node scripts/check-commit-author.mjs
if [ $? -ne 0 ]; then
  exit 1
fi

# ── Root file guard ──────────────────────────────────────────────
# Only these files are allowed at the project root. Everything else
# (especially .md, .js, .ts, .py, .sh) must go in docs/, scripts/, etc.
ALLOWED_ROOT="README.md|CLAUDE.md|AGENTS.md|CONTRIBUTING.md|WORKING_CONTEXT.md|DESIGN.md|CHANGELOG.md|LICENSE|LICENSE.md|.lintstagedrc.js"

STRAY_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E "^[^/]+\.(md|js|jsx|ts|tsx|mjs|cjs|py|sh|html)$" | grep -Ev "^($ALLOWED_ROOT)$" || true)

if [ -n "$STRAY_FILES" ]; then
  echo ""
  echo "ERROR: Files staged in the project root that belong elsewhere:"
  echo ""
  echo "$STRAY_FILES" | while read file; do
    echo "  - $file"
  done
  echo ""
  echo "Move them to the correct location:"
  echo "  .md files   -> docs/"
  echo "  .js/.jsx/.ts/.tsx/.mjs/.cjs -> scripts/ or frontend/src/"
  echo "  .py/.sh     -> scripts/"
  echo "  .html       -> docs/ or frontend/"
  echo ""
  echo "Allowed root files: $ALLOWED_ROOT"
  echo ""
  exit 1
fi

npm run check:routes
if [ $? -ne 0 ]; then
  echo "Route conflict found. Fix before committing."
  exit 1
fi

# ── Phantom-table guard ──────────────────────────────────────────
# Block commits that introduce .from("table") calls against tables
# not in the generated database.types.ts. See scripts/audits/.
node scripts/audits/check-no-new-phantom-tables.mjs --staged
if [ $? -ne 0 ]; then
  echo "Phantom table reference found. Fix before committing."
  exit 1
fi

npx lint-staged
