#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🚀 Running pre-push checks..."
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# Run full typecheck on entire project
echo "📝 Type checking entire project..."
npm run typecheck --prefix frontend
TYPECHECK_EXIT=$?

# Skip full lint on push — too slow with design-system warnings.
# Lint runs on pre-commit (staged files only) which is sufficient.

# Run unit tests to keep service layer coverage healthy
echo ""
echo "🧪 Running unit tests..."
npm run test:unit --prefix frontend
TEST_EXIT=$?

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# Block push if checks failed
if [ $TYPECHECK_EXIT -ne 0 ] || [ $TEST_EXIT -ne 0 ]; then
  echo "❌ Pre-push checks FAILED"
  echo ""
  echo "PUSH BLOCKED - Fix all errors before pushing"
  echo ""
  echo "Run these commands to see errors:"
  echo "  npm run typecheck --prefix frontend"
  echo "  npm run test:unit --prefix frontend"
  echo ""
  exit 1
fi

echo "✅ Pre-push checks PASSED - Push allowed"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
