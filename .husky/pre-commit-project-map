#!/usr/bin/env sh

# Project map freshness gate
# If staged changes add/remove/rename a UI route (page.tsx), an API route
# (route.ts), or an AI tool (lib/ai/tools), the generated surface inventory at
# docs/architecture/PROJECT-MAP.md must be regenerated and staged too. A stale
# map is worse than none — it lies to the next agent session.
#
# Regenerate with: npm run map:project

STAGED=$(git diff --cached --name-only --diff-filter=ACMRD)

if [ -z "$STAGED" ]; then
  exit 0
fi

# Only these paths change the map's contents.
SURFACE=$(echo "$STAGED" | grep -E '^frontend/src/app/.*/(page\.tsx|route\.ts)$|^frontend/src/lib/ai/tools/.*\.ts$|^frontend/src/lib/app-surface/page-descriptions\.json$' || true)

if [ -z "$SURFACE" ]; then
  exit 0
fi

node scripts/dev-tools/generate-project-map.mjs --check-only
if [ $? -ne 0 ]; then
  echo ""
  echo "Staged changes added/removed routes or AI tools but PROJECT-MAP.md is stale."
  echo "Run: npm run map:project && git add docs/architecture/PROJECT-MAP.md"
  exit 1
fi

echo "✅ Project map gate — surface inventory is current."

# Generated docs-site Reference pages (🟢) derive from the same surface. Verify
# they're current too. The script no-ops if the docs site (a symlink to the
# alleato-os repo) isn't checked out, so this is safe on CI / fresh clones.
# Note: those pages live in the alleato-os repo and are committed there.
node scripts/dev-tools/generate-docs-reference.mjs --check-only
if [ $? -ne 0 ]; then
  echo ""
  echo "Docs-site Reference pages are stale relative to the code."
  echo "Run: npm run docs:reference   (then commit them in the alleato-os repo)"
  exit 1
fi

exit 0
