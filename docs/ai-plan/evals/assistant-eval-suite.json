{
  "version": "2026-05-02",
  "description": "Comprehensive prompt suite for /ai-assistant. Each case names: the user's question, the intent it should be classified as, the tool families that should fire, specific tool names that the assistant SHOULD call (any-of), substrings the answer MUST contain, substrings it MUST NOT contain, and an optional pinned project_id. The runner POSTs each prompt to /api/ai-assistant/chat, drains the stream, then reads chat_history.metadata.tool_trace to score coverage.",
  "globalForbiddenPhrases": [
    "I found results",
    "I'll search",
    "Let me search",
    "I will search",
    "tool call",
    "RAG",
    "retrieval",
    "as an AI",
    "I cannot help"
  ],
