{
  "version": "2026-05-19",
  "description": "ISOLATED write/action tool coverage. These cases FIRE MUTATING TOOLS (create RFIs/commitments/change orders, write memory, and — critically — create real Outlook drafts/invites in Brandon's mailbox and send Teams DMs). They MUST NOT run against production. Run ONLY against a seeded, disposable, write-enabled environment with cleanup. No npm script references this file, so a default `rag:verify:eval-suite` run cannot pick these up. Several tools (draftOutlookEmail, createOutlookCalendarInvite, sendTeamsMessage) are Microsoft-operator tools stripped from the default Strategist by omitMicrosoftOperatorTools — they are only reachable on the operator-enabled surface behind the preview→confirm approval gate, so a passing run also requires that surface.",
  "requiresSeededEnv": true,
  "doNotRunAgainstProd": true,
  "globalForbiddenPhrases": [
    "I found results",
    "I'll search",
    "Let me search",
    "I will search",
    "tool call",
    "RAG",
    "retrieval",
    "as an AI",
    "I cannot help"
  ],
  "cases": [
