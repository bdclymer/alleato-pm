    "rag:verify:app-expert-evals:prod": "APP_EXPERT_EVAL_BACKEND_URL=https://alleato-backend-rbnj.onrender.com APP_EXPERT_EVAL_CASE_TIMEOUT_MS=120000 npm run rag:verify:app-expert-evals",
    "rag:verify:app-expert-smoke": "node scripts/verify/verify_app_expert_prod_smoke.mjs",
    "rag:verify:app-expert-smoke:prod": "APP_EXPERT_SMOKE_BACKEND_URL=https://alleato-backend-rbnj.onrender.com APP_EXPERT_SMOKE_TIMEOUT_MS=45000 npm run rag:verify:app-expert-smoke",
    "rag:verify:strategic-advisor-evals": "node scripts/verify/verify_ai_assistant_eval_suite.mjs --bundle strategic-advisor-quality",
