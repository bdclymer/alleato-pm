    "rag:backfill:source-lifecycle": "node scripts/verify/backfill_source_lifecycle_from_current_state.mjs",
    "rag:backfill:project-assignments": "node scripts/verify/backfill_project_assignments_from_compiler_jobs.mjs",
    "rag:backfill:onedrive-project-paths": "node scripts/verify/backfill_onedrive_project_assignments_from_source_path.mjs",
    "tasks:extract-brandon": "node scripts/backfill-brandon-tasks.mjs",
    "tasks:extract-brandon:dry": "node scripts/backfill-brandon-tasks.mjs --dry-run",
    "rag:verify:financial": "bash -lc 'PY=python3; [ -x backend/.venv/bin/python ] && PY=backend/.venv/bin/python; $PY scripts/verify/verify_financial_numeric_retrieval.py --project-id ${RAG_VERIFY_PROJECT_ID:-43}'",
    "rag:verify:financial:fallback": "bash -lc 'PY=python3; [ -x backend/.venv/bin/python ] && PY=backend/.venv/bin/python; $PY scripts/verify/verify_financial_fallback_retrieval.py --project-id ${RAG_VERIFY_PROJECT_ID:-43}'",
