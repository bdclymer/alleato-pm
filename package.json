    "rag:verify:excalidraw-mcp": "node scripts/verify/verify_ai_assistant_excalidraw_mcp.mjs",
    "rag:verify:latest-briefing": "node scripts/verify/verify_ai_assistant_latest_briefing_shape.mjs",
    "rag:verify:executive-daily-brief": "node scripts/verify/verify_executive_daily_brief_fresh.mjs",
