{
  "name": "alleato-procore",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && ./start.sh",
    "build": "pnpm --dir frontend install --frozen-lockfile && pnpm --dir frontend run build",
    "start": "cd frontend && npm start",
    "install:all": "npm install && cd frontend && npm install",
    "test": "npm run test:frontend && npm run test:backend",
    "test:frontend": "cd frontend && npm run test:unit",
    "test:backend": "cd backend && pytest",
    "test:all": "./scripts/misc/run-all-tests.sh",
    "test:coverage": "npm run test:frontend:coverage && npm run test:backend:coverage",
    "test:frontend:coverage": "cd frontend && npm run test:unit:coverage",
    "test:backend:coverage": "cd backend && pytest --cov --cov-report=html",
    "seed:sync": "npx @snaplet/seed sync && node scripts/seed-db/fix-snaplet-models.cjs",
    "seed:db": "npx tsx scripts/seed-db/seed-database.ts",
    "seed:db:dry": "npx tsx scripts/seed-db/seed-database.ts --dry-run",
    "seed:db:reset": "npx tsx scripts/seed-db/seed-database.ts --reset",
    "seed:financial": "npx tsx scripts/seed-db/seed-financial-data.ts",
    "seed:project": "npx tsx scripts/seed-db/seed-project-financial-data.ts",
    "schema:extract": "node scripts/database/generate-schema-from-types.js",
    "schema:docs": "npm run schema:extract && node scripts/database/generate-schema-docs.js",
    "db:types": "npx supabase gen types typescript --project-id lgveqfnpkxvzbnnwuled --schema public > frontend/src/types/database.types.ts && npm run devtools:sync-schema-fk",
    "db:audit": "cd frontend && npm run audit:db && npm run audit:db:fk-types",
    "db:push": "supabase db push && npm run db:types",
    "devtools:sync-schema-fk": "node scripts/dev-tools/generate-page-schema-fk-map.mjs",
    "check:routes": "bash scripts/check-route-conflicts.sh",
    "gen:playwright-prompt": "node scripts/generate-playwright-skill-prompt.cjs",
    "gen:playwright-prompt:all": "node scripts/generate-playwright-skill-prompts-batch.cjs",
    "dashboard:playwright": "node scripts/build-playwright-dashboard.cjs",
    "dashboard:playwright:open": "npm run dashboard:playwright && open output/playwright/dashboard/index.html",
    "verify:browser": "node scripts/agent-browser/agent-browser-verify.mjs",
    "verify:browser:cleanup": "node scripts/agent-browser/agent-browser-cleanup.mjs --hours 48",
    "lint:md": "markdownlint-cli2",
    "lint:md:fix": "markdownlint-cli2 --fix",
    "cache:verify": "npx tsx scripts/verify-cache-setup.ts",
    "cache:stats": "npx tsx scripts/cache-monitor.ts summary",
    "cache:recent": "npx tsx scripts/cache-monitor.ts recent",
    "cache:export": "npx tsx scripts/cache-monitor.ts export",
    "cache:reset": "npx tsx scripts/cache-monitor.ts reset",
    "rag:ingest:local": "python3 scripts/ingestion/ingest_local_documents.py",
    "rag:ingest:local:watch": "python3 scripts/ingestion/ingest_local_documents.py --watch",
    "rag:verify:financial": "python3 scripts/verify/verify_financial_numeric_retrieval.py",
    "rag:verify:financial:fallback": "python3 scripts/verify/verify_financial_fallback_retrieval.py",
    "rag:verify:risk-routing": "python3 scripts/verify/verify_ai_assistant_risk_routing.py",
    "rag:verify:risk-quality": "python3 scripts/verify/verify_ai_assistant_risk_quality.py",
    "rag:verify:task-integrity": "python3 scripts/verify/verify_fireflies_task_integrity.py"
  },
  "devDependencies": {
    "@playwright/mcp": "^0.0.63",
    "@playwright/test": "^1.58.2",
    "@snaplet/copycat": "^6.0.0",
    "@snaplet/seed": "^0.98.0",
    "@types/node": "^25.1.0",
    "@types/pg": "^8.16.0",
    "autoprefixer": "^10.4.23",
    "chokidar": "^5.0.0",
    "concurrently": "^9.1.2",
    "dotenv": "^17.2.3",
    "js-yaml": "^4.1.1",
    "markdownlint-cli2": "^0.20.0",
    "pg": "^8.16.3",
    "postgres": "^3.4.7",
    "storybook-dark-mode": "^4.0.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.72.1",
    "@google/stitch-sdk": "^0.0.3",
    "ai": "^6.0.134",
    "lucide-react": "^0.562.0",
    "motion": "^12.23.26",
    "resend": "^6.9.1"
  },
  "main": ".lintstagedrc.js",
  "directories": {
    "doc": "docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MeganHarrison/alleato-pm.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/MeganHarrison/alleato-pm/issues"
  },
  "homepage": "https://github.com/MeganHarrison/alleato-pm#readme",
  "description": ""
}
