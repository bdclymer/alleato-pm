    "db:migrations:verify-applied": "node scripts/ops/check-supabase-migration-ledger.mjs",
    "db:migrations:verify-clean": "node scripts/ops/check-supabase-migration-ledger.mjs --all",
    "devtools:sync-schema-fk": "node scripts/dev-tools/generate-page-schema-fk-map.mjs",
    "check:routes": "bash scripts/check-route-conflicts.sh",
    "check:doc-tables": "node scripts/audits/check-no-phantom-doc-tables.mjs --staged",
    "check:pdf-tracing": "node scripts/audits/check-pdf-route-tracing.mjs",
