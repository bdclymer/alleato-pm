    "rag:ingest:estimating:dry": "bash -lc 'PY=python3; [ -x backend/.venv/bin/python ] && PY=backend/.venv/bin/python; PYTHONPATH=\"$PWD/backend${PYTHONPATH:+:$PYTHONPATH}\" $PY scripts/ingestion/ingest_local_documents.py --source-dir \"${RAG_ESTIMATING_SOURCE_DIR:-docs/PRPs/estimates}\" --manifest tmp/rag-ingestion/estimating-manifest.json --source-label estimating --workflow-target estimating --storage-prefix local/estimating --category financial_document --stable-source-ids --dry-run \"$@\"' --",
