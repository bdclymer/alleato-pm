    "verify:browser:cleanup": "node scripts/agent-browser/agent-browser-cleanup.mjs --hours 48",
    "perf:project-home": "node scripts/perf/project-home-speed.mjs",
    "verify:budget:guardrails": "cd frontend && npm run verify:budget:guardrails",
    "verify:api:contracts": "node scripts/api-smoke-contracts.mjs",
