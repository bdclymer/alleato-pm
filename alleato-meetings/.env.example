# ── Alleato Meetings — environment ────────────────────────────────────────────
# Copy to .env.local for local dev, or set these in your Vercel project.

# Supabase (this app's OWN project — separate from alleato-pm)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Microsoft Graph (app-only / client credentials)
# Reuse the existing Alleato Graph app registration, or create a dedicated one.
# Requires admin-consented application permissions:
#   OnlineMeetingTranscript.Read.All, OnlineMeetingRecording.Read.All, OnlineMeetings.Read.All
# AND a Teams application access policy granted to MS_CLIENT_ID.
MS_TENANT_ID=alleatogroup.com
MS_CLIENT_ID=your-app-client-id
MS_CLIENT_SECRET=your-app-client-secret

# OpenAI (AI summary + action item extraction)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Shared secret that protects POST /api/sync (send as `x-sync-secret` header / cron)
SYNC_SECRET=generate-a-long-random-string

# Simple password gate for the UI (basic-auth middleware). Set a strong value.
APP_PASSWORD=change-me
