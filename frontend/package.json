{
  "name": "alleato-procore",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "pnpm": {
    "patchedDependencies": {
      "agentation@3.0.2": "patches/agentation@3.0.2.patch"
    }
  },
  "scripts": {
    "postinstall": "rm -rf .next 2>/dev/null || true",
    "dev": "bash ../scripts/dev/start-frontend-clean.sh",
    "dev:clean": "bash ../scripts/dev/start-frontend-clean.sh",
    "build": "NODE_OPTIONS='--max-old-space-size=7168' next build",
    "start": "next start",
    "email:preview": "email dev --dir src/emails --port 3030",
    "lint": "eslint . --cache --cache-strategy content",
    "set-admin": "node scripts/set-admin.mjs",
    "typecheck": "tsc --noEmit",
    "audit:db": "tsx scripts/audit/audit-db-inserts.ts",
    "audit:db:fk-types": "node --require tsx/cjs scripts/audit/audit-db-fk-and-validation.ts",
    "audit:db:ambiguous-embeds": "node --require tsx/cjs scripts/audit/audit-db-ambiguous-embeds.ts",
    "audit:forms": "node --require tsx/cjs scripts/audit/audit-form-field-standards.ts",
    "audit:forms:components": "node scripts/audit/audit-form-components.mjs",
    "test": "playwright test --config=config/playwright/playwright.config.ts",
    "test:ui": "playwright test --config=config/playwright/playwright.config.ts --ui",
    "test:headed": "playwright test --config=config/playwright/playwright.config.ts --headed",
    "test:auth": "playwright test tests/e2e/auth/auth.spec.ts --config=config/playwright/playwright.config.ts",
    "test:report": "playwright show-report tests/playwright-report",
    "test:visual": "playwright test --config=config/playwright/playwright.config.visual.ts",
    "test:visual:update": "playwright test --config=config/playwright/playwright.config.visual.ts --update-snapshots",
    "test:visual:report": "playwright show-report tests/visual-regression-report",
    "test:video": "playwright test --config=config/playwright/playwright.config.video.ts",
    "test:video:ui": "playwright test --config=config/playwright/playwright.config.video.ts --ui",
    "test:performance": "playwright test tests/e2e/directory/directory-performance.spec.ts --config=config/playwright/playwright.config.ts",
    "test:performance:report": "playwright show-report tests/performance-report",
    "test:allure:report": "npx allure generate tests/allure-results --clean -o tests/allure-report",
    "test:allure:open": "npx allure open tests/allure-report",
    "test:unit": "jest",
    "test:unit:watch": "jest --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:unit:coverage": "jest --coverage",
    "test:unit:ci": "jest --ci --coverage --maxWorkers=2",
    "verify:budget:guardrails": "jest --runInBand --runTestsByPath 'src/lib/budget/update-budget-line-item.unit.test.ts' 'src/app/api/projects/[projectId]/budget/lines/[lineId]/__tests__/route.test.ts'",
    "test:forms": "playwright test tests/e2e/ui/comprehensive-form-testing.spec.ts --config=config/playwright/playwright.config.ts",
    "test:forms:ui": "playwright test tests/e2e/ui/comprehensive-form-testing.spec.ts --config=config/playwright/playwright.config.ts --ui",
    "test:forms:headed": "playwright test tests/e2e/ui/comprehensive-form-testing.spec.ts --config=config/playwright/playwright.config.ts --headed",
    "test:debug": "playwright test --config=config/playwright/playwright.config.ts --debug",
    "test:trace": "playwright test --config=config/playwright/playwright.config.ts --trace on",
    "test:shard:1": "playwright test --config=config/playwright/playwright.config.ts --shard=1/4",
    "test:shard:2": "playwright test --config=config/playwright/playwright.config.ts --shard=2/4",
    "test:shard:3": "playwright test --config=config/playwright/playwright.config.ts --shard=3/4",
    "test:shard:4": "playwright test --config=config/playwright/playwright.config.ts --shard=4/4",
    "test:submittals:smoke": "node ../scripts/seed-db/seed-submittals-smoke.js && playwright test tests/e2e/submittals/submittals.smoke.spec.ts --config=config/playwright/playwright.config.ts --reporter=html",
    "test:submittals:smoke:serve": "concurrently -k -s first \"npm run dev -- --port 3002\" \"node ../scripts/wait-for-http.js http://localhost:3002 && npm run test:submittals:smoke\"",
    "seed:test": "node ../scripts/seed-db/seed-test-data.js",
    "seed:test:full": "npx tsx ../scripts/seed-db/seed-test-data.ts",
    "seed:test:clear": "npx tsx ../scripts/seed-db/seed-test-data.ts --clean",
    "prepare": "cd .. && husky",
    "lint:fix": "eslint . --fix --cache --cache-strategy content",
    "lint:changed:debt": "node scripts/check-no-new-eslint-debt.mjs",
    "typecheck:changed": "cd .. && node scripts/check-no-new-any.mjs",
    "guardrails:unsafe-patterns": "cd .. && node scripts/check-no-new-unsafe-patterns.mjs",
    "guardrails:changed": "cd .. && GUARDRAIL_ENFORCE_RAW_ERRORS=true node scripts/check-changed-route-guardrails.mjs",
    "quality:changed": "npm run lint:changed:debt && npm run typecheck:changed && npm run guardrails:unsafe-patterns && GUARDRAIL_ENFORCE_RAW_ERRORS=true npm run guardrails:changed",
    "quality": "npm run typecheck && npm run lint && npm run audit:forms",
    "quality:fix": "npm run typecheck && npm run lint:fix && npm run audit:forms",
    "log:ts-errors": "npx tsx scripts/log-typescript-errors.ts",
    "audit:table-layouts": "node scripts/audit-table-layouts.mjs",
    "audit:modals": "node scripts/audit-modals.mjs",
    "design:ratchet": "node scripts/design-system/check-ratchet.mjs",
    "design:ratchet:update-baseline": "node scripts/design-system/check-ratchet.mjs --write-baseline",
    "design:no-new-disables": "node scripts/design-system/check-no-new-disables.mjs",
    "design:no-new-form-violations": "node scripts/design-system/check-no-new-form-violations.mjs",
    "codemod:forms:placeholder-zero": "node scripts/codemods/normalize-zero-placeholders.mjs",
    "chromatic": "chromatic --project-token=$CHROMATIC_PROJECT_TOKEN --build-script-name=build-storybook"
  },
