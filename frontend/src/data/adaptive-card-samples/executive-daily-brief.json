            },
            {
              "type": "ColumnSet",
              "spacing": "Small",
              "separator": true,
              "columns": [
                {
                  "type": "Column",
                  "width": "60px",
                  "items": [
                    {
                      "type": "TextBlock",
                      "text": "2:00 PM",
                      "size": "Small",
                      "isSubtle": true,
                      "wrap": false
                    }
                  ]
                },
                {
                  "type": "Column",
                  "width": "stretch",
                  "spacing": "Small",
                  "items": [
                    {
                      "type": "TextBlock",
                      "text": "Budget Review — Vermillion Rise",
                      "size": "Small",
                      "weight": "Bolder",
                      "wrap": true
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "Reply with a project name to drill down or draft a follow-up.",
      "size": "Small",
      "isSubtle": true,
      "wrap": true,
      "spacing": "Medium",
      "separator": true
    }
