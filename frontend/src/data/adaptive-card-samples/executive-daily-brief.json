              "type": "ColumnSet",
              "columns": [
                {
                  "type": "Column",
                  "width": "auto",
                  "verticalContentAlignment": "Top",
                  "items": [
                    {
                      "type": "Icon",
                      "name": "Clock",
                      "size": "xxSmall",
                      "color": "Warning"
                    }
