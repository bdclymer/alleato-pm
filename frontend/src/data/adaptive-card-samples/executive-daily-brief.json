                {
                  "type": "Column",
                  "width": "stretch",
                  "spacing": "Small",
                  "items": [
                    {
                      "type": "TextBlock",
                      "text": "OAC Meeting — Union Collective",
                      "size": "Small",
                      "weight": "Bolder",
                      "wrap": true
                    }
                  ]
