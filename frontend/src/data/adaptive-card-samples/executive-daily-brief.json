                  ]
                }
              ]
            },
            {
              "type": "ColumnSet",
              "spacing": "Small",
              "separator": true,
              "columns": [
                {
                  "type": "Column",
                  "width": "auto",
                  "verticalContentAlignment": "Top",
                  "items": [
                    {
                      "type": "TextBlock",
                      "text": "3",
                      "size": "Small",
                      "weight": "Bolder",
                      "color": "Attention"
                    }
                  ]
                },
                {
                  "type": "Column",
                  "width": "stretch",
                  "spacing": "Small",
                  "items": [
                    {
                      "type": "TextBlock",
                      "text": "Maple Street Mixed-Use",
                      "size": "Small",
                      "weight": "Bolder",
                      "wrap": true
                    },
                    {
                      "type": "TextBlock",
                      "text": "GC requesting confirmation on MEP coordination scope before submitting RFI response.",
