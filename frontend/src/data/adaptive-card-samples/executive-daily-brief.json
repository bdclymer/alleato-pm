            {
              "type": "Column",
              "width": "auto",
              "verticalContentAlignment": "Center",
              "items": [
                {
                  "type": "Icon",
                  "name": "ChevronDown",
                  "size": "xSmall",
                  "id": "decisions-chevron-down",
                  "isVisible": false
                },
                {
                  "type": "Icon",
                  "name": "ChevronUp",
                  "size": "xSmall",
                  "id": "decisions-chevron-up"
