                      "isSubtle": true,
                      "wrap": true,
                      "spacing": "None"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "spacing": "Small",
      "separator": true,
      "items": [
        {
          "type": "ColumnSet",
          "selectAction": {
            "type": "Action.ToggleVisibility",
            "targetElements": [
              "pending-items",
              "pending-chevron-down",
              "pending-chevron-up"
