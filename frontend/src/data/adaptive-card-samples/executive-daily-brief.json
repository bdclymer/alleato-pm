                {
                  "type": "Column",
                  "width": "auto",
                  "verticalContentAlignment": "Top",
                  "items": [
                    {
                      "type": "TextBlock",
                      "text": "6d",
                      "size": "Small",
                      "color": "Warning",
                      "weight": "Bolder"
                    }
                  ]
                }
              ]
            },
            {
              "type": "ColumnSet",
              "spacing": "Small",
              "separator": true,
              "columns": [
                {
                  "type": "Column",
                  "width": "auto",
                  "verticalContentAlignment": "Top",
                  "items": [
                    {
                      "type": "Icon",
                      "name": "Clock",
                      "size": "xxSmall",
                      "color": "Default"
                    }
                  ]
                },
                {
                  "type": "Column",
                  "width": "stretch",
                  "spacing": "Small",
                  "items": [
                    {
                      "type": "TextBlock",
                      "text": "Union Collective",
                      "size": "Small",
                      "weight": "Bolder",
                      "wrap": true
                    },
                    {
                      "type": "TextBlock",
                      "text": "Owner review of value engineering options — awaiting response since Monday.",
                      "size": "Small",
                      "isSubtle": true,
                      "wrap": true,
                      "spacing": "None"
                    }
                  ]
                },
                {
                  "type": "Column",
                  "width": "auto",
                  "verticalContentAlignment": "Top",
                  "items": [
                    {
                      "type": "TextBlock",
                      "text": "2d",
                      "size": "Small",
                      "isSubtle": true,
                      "weight": "Bolder"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "spacing": "Small",
      "separator": true,
      "items": [
        {
          "type": "ColumnSet",
          "selectAction": {
            "type": "Action.ToggleVisibility",
            "targetElements": [
              "meetings-items",
              "meetings-chevron-down",
              "meetings-chevron-up"
