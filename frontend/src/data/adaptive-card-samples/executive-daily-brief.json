            {
              "type": "Column",
              "width": "auto",
              "verticalContentAlignment": "Center",
              "items": [
                {
                  "type": "Icon",
                  "name": "ChevronDown",
                  "size": "xSmall",
                  "id": "meetings-chevron-down"
