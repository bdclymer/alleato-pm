{
  "type": "AdaptiveCard",
  "$schema": "https://adaptivecards.io/schemas/adaptive-card.json",
  "version": "1.5",
  "body": [
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "Daily Brief",
              "size": "Large",
              "weight": "Bolder",
              "wrap": false
            },
            {
              "type": "TextBlock",
              "text": "Tuesday, June 10, 2026",
              "size": "Small",
              "isSubtle": true,
              "spacing": "None",
              "wrap": false
            }
          ]
        },
        {
          "type": "Column",
          "width": "auto",
          "verticalContentAlignment": "Top",
          "items": [
            {
              "type": "TextBlock",
              "text": "Good morning, Brandon.",
              "size": "Small",
              "isSubtle": true,
              "horizontalAlignment": "Right",
              "wrap": true
            }
          ]
        }
      ]
    },
    {
      "type": "ColumnSet",
      "spacing": "Medium",
      "separator": true,
      "columns": [
        {
          "type": "Column",
          "width": "auto",
          "verticalContentAlignment": "Center",
          "items": [
            {
              "type": "Icon",
              "name": "Alert",
              "size": "xSmall",
              "color": "Attention"
            }
          ]
        },
        {
          "type": "Column",
          "width": "stretch",
          "spacing": "Small",
          "verticalContentAlignment": "Center",
          "items": [
            {
              "type": "RichTextBlock",
              "inlines": [
                {
                  "type": "TextRun",
                  "text": "3 decisions needed",
                  "weight": "Bolder",
                  "color": "Attention"
                },
                {
                  "type": "TextRun",
                  "text": "  ·  5 pending  ·  2 meetings today"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "spacing": "Medium",
      "separator": true,
      "items": [
        {
          "type": "ColumnSet",
          "selectAction": {
            "type": "Action.ToggleVisibility",
            "targetElements": [
              "decisions-items",
              "decisions-chevron-down",
              "decisions-chevron-up"
            ]
          },
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Decisions Needed",
                  "weight": "Bolder",
                  "wrap": true
                }
              ]
