{
  "framework": "nextjs",
  "installCommand": "pnpm --dir frontend install --frozen-lockfile --ignore-scripts",
  "buildCommand": "cd frontend && NODE_OPTIONS='--max-old-space-size=7168' pnpm run build",
  "crons": [
    { "path": "/api/cron/decay-memories", "schedule": "0 4 * * 0" },
    { "path": "/api/cron/daily-flags", "schedule": "0 6 * * *" }
  ]
}
