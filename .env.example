# Alleato-Procore Change Orders Environment Configuration
# Copy this file to .env and update with your actual values
# For frontend-specific config, see frontend/.env.local.development

# =============================================================================
# EXISTING CONFIGURATION (already in frontend/.env)
# =============================================================================
# Supabase Configuration - See frontend/.env.local.development for defaults
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional external alerting for high-severity/repeated API guardrail errors.
# Local development works without this; production/preview logs a startup warning
# if it is missing so alert suppression fails loudly.
# ERROR_ALERT_WEBHOOK_URL=https://hooks.example.com/...

# Tavus live AI strategist avatar
# Keep these server-side only. The app creates Tavus conversations from
# /api/ai-assistant/avatar/conversation and embeds the returned conversation_url.
# TAVUS_API_KEY=tavus-your-api-key
# TAVUS_PERSONA_ID=p_your-strategist-persona-id
# TAVUS_REPLICA_ID=r_your-ready-replica-id

# AI assistant voice playback
# Used server-side by /api/ai-assistant/speech to read assistant responses aloud.
# OPENAI_API_KEY=sk-your-openai-api-key

# =============================================================================
# CHANGE ORDERS FEATURE - ADDITIONAL CONFIGURATION
# =============================================================================

# Email Notifications (for approval workflows)
# Choose one email provider and configure:

# Option 1: Resend (Recommended - already in dependencies)
RESEND_API_KEY=re_your-api-key-here
# Get from: https://resend.com/api-keys

# Option 2: SendGrid
# SENDGRID_API_KEY=SG.your-api-key-here
# Get from: https://app.sendgrid.com/settings/api_keys

# Option 3: AWS SES
# AWS_SES_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# Email sender configuration
# EMAIL_FROM_ADDRESS=noreply@yourdomain.com
# EMAIL_FROM_NAME=Your Company Name

# =============================================================================
# PDF GENERATION (Optional)
# =============================================================================
# If using a cloud PDF service instead of local generation
# PDF_SERVICE_URL=https://your-pdf-service.com
# PDF_SERVICE_API_KEY=your-api-key

# =============================================================================
# FEATURE FLAGS (Optional)
# =============================================================================
# Enable/disable specific Change Orders features
# FEATURE_MULTI_TIER_APPROVAL=true
# FEATURE_DOCUSIGN_INTEGRATION=false
# FEATURE_EMAIL_NOTIFICATIONS=true
# Testing: set true to re-enable scenario depth filtering in admin testing flows
# TESTING_SCENARIO_DEPTH_FILTER_ENABLED=false
# NEXT_PUBLIC_TESTING_SCENARIO_DEPTH_FILTER_ENABLED=false
#
# Budget: when a prime contract is executed, force new budget line items to $0.00.
# Default ON. Set to "false" to allow PMs to add new lines with non-zero amounts
# even after the contract is executed.
# NEXT_PUBLIC_LOCK_NEW_BUDGET_LINE_AMOUNTS_AFTER_CONTRACT_EXECUTION=true

# =============================================================================
# DEVELOPMENT / TESTING
# =============================================================================
# Test user credentials (for Playwright tests)
# These are already configured in the project
# PROCORE_USER=          # See frontend/.env.local.development
# PROCORE_PASSWORD=      # See frontend/.env.local.development

# Claude API (for AI features)
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Get from: https://console.anthropic.com/settings/keys

# =============================================================================
# FEEDBACK COLLABORATION (Production Beta)
# =============================================================================
# PostHog — session replay, product analytics, surveys.
# Get a project key from https://app.posthog.com/project/settings
# NEXT_PUBLIC_POSTHOG_KEY=phc_your-project-key
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry — error tracking + replays on error.
# Get a DSN from https://sentry.io → Project Settings → Client Keys
# NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@oXXXX.ingest.us.sentry.io/XXXX
# SENTRY_DSN=https://your-dsn@oXXXX.ingest.us.sentry.io/XXXX  # optional; server-only fallback
# SENTRY_BACKEND_DSN=https://your-backend-dsn@oXXXX.ingest.us.sentry.io/XXXX
# SENTRY_ORG=your-sentry-org
# SENTRY_PROJECT=your-sentry-nextjs-project
# SENTRY_AUTH_TOKEN=sntrys_your_source_map_upload_token
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.1
# SENTRY_SEND_DEFAULT_PII=false
# NEXT_PUBLIC_SENTRY_SEND_DEFAULT_PII=false

# Microsoft Teams — notification of every feedback submission.
# Create with Teams → Channel → Workflows → "Post to a channel when a webhook
# request is received". Copy the resulting Power Automate URL.
# TEAMS_FEEDBACK_WEBHOOK_URL=https://prod-XX.westus.logic.azure.com:443/workflows/...

# Optional: explicit app URL used in Teams "Open in feedback inbox" links.
# Falls back to the originating request URL if unset.
# NEXT_PUBLIC_APP_URL=https://app.alleato.ai
